function saveResident() {
  const floor=+document.getElementById('res-floor').value;
  const apt=+document.getElementById('res-apt').value;
  const owner=document.getElementById('res-owner').value.trim();
  if(!apt||!owner){toast('Тоот болон эзэмшигчийн нэрийг оруулна уу','error');return;}
  const data={floor,apt,owner,reg:document.getElementById('res-reg').value,phone:document.getElementById('res-phone').value,
    email:document.getElementById('res-email').value,people:+document.getElementById('res-people').value,
    sqm:+document.getElementById('res-sqm').value,note:document.getElementById('res-note').value};
  if(editingResidentId) {
    const idx=residents.findIndex(r=>r.id===editingResidentId);
    if(idx>=0) residents[idx]={...residents[idx],...data};
    toast('Мэдээлэл шинэчлэгдлээ ✓','success');
  } else {
    if(residents.some(r=>r.apt===apt)){toast('Тоот аль хэдийн бүртгэлтэй байна','error');return;}
    residents.push({id:nextId++,...data});
    toast('Оршин суугч нэмэгдлээ ✓','success');
  }
  closeModal('modal-resident');
  renderResidents();
}

function deleteResident(id) {
  if(!confirm('Устгах уу?')) return;
  residents = residents.filter(r=>r.id!==id);
  renderResidents();
  toast('Устгагдлаа','success');
}

