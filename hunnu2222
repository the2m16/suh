  if(r) document.getElementById('pay-amount').value = calcFee(r.sqm);
  document.getElementById('pay-ref').value='';
  openModal('modal-payment');
}

function selectPayMethod(el, method) {
  document.querySelectorAll('.pay-method-card').forEach(c=>c.classList.remove('selected'));
  el.classList.add('selected');
  document.getElementById('pay-method').value=method;
  document.getElementById('qpay-info').style.display = method==='qpay'?'block':'none';
}

function savePayment() {
  const resId = +document.getElementById('pay-apt-select').value;
  const r = residents.find(x=>x.id===resId);
  const amount = +document.getElementById('pay-amount').value;
  const method = document.getElementById('pay-method').value;
  const ref = document.getElementById('pay-ref').value;
  const month = +document.getElementById('pay-month').value;
  if(!amount){toast('Дүн оруулна уу','error');return;}
  const now=new Date();
  transactions.push({id:nextId++,aptId:r.id,apt:r.apt,desc:'Сарын хураамж',type:'income',amount,method,ref,month,year:now.getFullYear(),date:now.toISOString().slice(0,10),status:'completed'});
  toast(`${r.apt} тоотын төлбөр бүртгэгдлээ ✓`,'success');
  closeModal('modal-payment');
  renderPaymentsTable('pending');
}

// ============================================================
// APARTMENTS GRID
// ============================================================
function renderFloorFilter() {
  const sel = document.getElementById('apt-floor-filter');
  if(sel.options.length>1) return;
  for(let f=1;f<=FLOORS;f++) {
    const opt = document.createElement('option');
    opt.value=f; opt.textContent=f+'-р давхар';
    sel.appendChild(opt);
  }
}

function renderAptGrid() {
  const filter = document.getElementById('apt-floor-filter').value;
  const now = new Date(); const thisMonth = now.getMonth()+1;
  const paidApts = transactions.filter(t=>t.type==='income'&&t.month===thisMonth).map(t=>t.apt);
  const container = document.getElementById('apt-grid-container');
  container.innerHTML='';
  for(let f=FLOORS;f>=1;f--) {
    if(filter && +filter!==f) continue;
    const row = document.createElement('div');
    row.className='apt-floor-row';
    const lbl=document.createElement('div');
    lbl.className='floor-label'; lbl.textContent=f+'Д';
    row.appendChild(lbl);
    for(let u=1;u<=APTS_PER_FLOOR;u++) {
      const aptNum=f*100+u;
      const res=residents.find(r=>r.apt===aptNum);
      const paid=paidApts.includes(aptNum);
      let cls='empty';
      if(res) cls=paid?'paid':'overdue';
      const cell=document.createElement('div');
      cell.className='apt-unit '+cls;
      cell.innerHTML=`<span>${aptNum}</span><span style="font-size:8px;opacity:.7">${res?res.sqm+'м²':'—'}</span>`;
      cell.onclick=()=>showAptDetail(aptNum,res,paid);
      row.appendChild(cell);
    }
    container.appendChild(row);
  }
}

function showAptDetail(aptNum, res, paid) {
  selectedAptForDetail = res;
  document.getElementById('apt-detail-title').textContent = aptNum+' тоот';
  const now=new Date(); const thisMonth=now.getMonth()+1;
  const history = transactions.filter(t=>t.apt===aptNum&&t.type==='income').sort((a,b)=>b.id-a.id).slice(0,5);
  document.getElementById('apt-detail-body').innerHTML = res ? `
    <div class="flex-between mb-16">
      <div><div style="font-size:18px;font-weight:800">${res.owner}</div><div style="color:var(--text-muted);font-size:13px">${res.phone} • ${res.email}</div></div>
      <span class="tag ${paid?'tag-success':'tag-danger'} "style="font-size:13px;padding:6px 14px">${paid?'✓ Төлсөн':'✗ Төлөөгүй'}</span>
    </div>
    <div class="summary-row"><span class="summary-key">Давхар / Тоот</span><span class="summary-val">${res.floor}-р давхар, ${res.apt}</span></div>
    <div class="summary-row"><span class="summary-key">Талбай</span><span class="summary-val">${res.sqm} м²</span></div>
    <div class="summary-row"><span class="summary-key">Хүн ам</span><span class="summary-val">${res.people} хүн</span></div>
    <div class="summary-row"><span class="summary-key">Сарын хураамж</span><span class="summary-val text-accent">${fmt(calcFee(res.sqm))}</span></div>
    <hr class="divider">
    <div class="card-title mb-8">Төлбөрийн түүх</div>
    ${history.length?history.map(t=>`<div class="summary-row"><span class="summary-key">${t.year}-${t.month}р сар ${methodIcon(t.method)}</span><span class="summary-val text-success">${fmt(t.amount)}</span></div>`).join(''):'<div style="color:var(--text-muted);font-size:13px">Түүх байхгүй</div>'}
  ` : `<div class="empty-state"><div class="empty-icon">🏠</div><div>Энэ тоотод оршин суугч бүртгэлгүй байна</div></div>`;
  openModal('modal-apt-detail');
}

function quickPay() {
  if(!selectedAptForDetail){closeModal('modal-apt-detail');return;}
  closeModal('modal-apt-detail');
  quickPayForApt(selectedAptForDetail.id);
}

// ============================================================
// REPORTS
// ============================================================
function generateReport(type) {
  const el = document.getElementById('report-output');
  const title = document.getElementById('report-title');
  const body = document.getElementById('report-body');
  el.style.display='block';
  el.scrollIntoView({behavior:'smooth'});
  const now = new Date();
  const thisMonth = now.getMonth()+1;
  if(type==='income') {
    title.textContent='📈 Орлогын тайлан — 2025 оны '+thisMonth+'-р сар';
    const monthTx = transactions.filter(t=>t.type==='income'&&t.month===thisMonth);
    const total = monthTx.reduce((s,t)=>s+t.amount,0);
    const expected = residents.reduce((s,r)=>s+calcFee(r.sqm),0);
    body.innerHTML=`
      <div class="grid-2 mb-16">
        <div><div class="summary-row"><span class="summary-key">Нийт орлого</span><span class="summary-val text-success">${fmt(total)}</span></div>
        <div class="summary-row"><span class="summary-key">Хүлээгдэж буй орлого</span><span class="summary-val">${fmt(expected)}</span></div>
        <div class="summary-row"><span class="summary-key">Цуглуулалтын хувь</span><span class="summary-val">${Math.round(total/expected*100)}%</span></div></div>
        <div><div class="summary-row"><span class="summary-key">Төлсөн тоот</span><span class="summary-val">${monthTx.length}</span></div>
        <div class="summary-row"><span class="summary-key">Нийт тоот</span><span class="summary-val">${residents.length}</span></div></div>
      </div>
      <table><thead><tr><th>Тоот</th><th>Эзэмшигч</th><th>Дүн</th><th>Арга</th><th>Огноо</th></tr></thead>
      <tbody>${monthTx.map(t=>{const r=residents.find(x=>x.apt===t.apt);return`<tr><td>${t.apt}</td><td>${r?r.owner:'—'}</td><td class="text-success font-mono">${fmt(t.amount)}</td><td>${methodName(t.method)}</td><td>${t.date}</td></tr>`;}).join('')}</tbody></table>`;
  } else if(type==='expense') {
    title.textContent='📉 Зарлагын тайлан — 2025';
    const exps = transactions.filter(t=>t.type==='expense');
    const total = exps.reduce((s,t)=>s+t.amount,0);
    const catNames = {utility:'Ашиглалтын зардал',maintenance:'Засвар',cleaning:'Цэвэрлэгээ',security:'Хамгаалалт',other:'Бусад'};
    const byCat = {};
    exps.forEach(t=>{byCat[t.category]=(byCat[t.category]||0)+t.amount;});
    body.innerHTML=`
      <div class="mb-16">${Object.entries(byCat).map(([c,v])=>`<div class="summary-row"><span class="summary-key">${catNames[c]||c}</span><span class="summary-val text-danger">${fmt(v)}</span></div>`).join('')}
      <div class="summary-row" style="border-top:1px solid var(--border)"><span class="summary-key font-bold" style="font-weight:700">Нийт зарлага</span><span class="summary-val text-danger" style="font-size:18px">${fmt(total)}</span></div></div>
      <table><thead><tr><th>Огноо</th><th>Ангилал</th><th>Тайлбар</th><th>Дүн</th></tr></thead>
      <tbody>${exps.map(t=>`<tr><td>${t.date}</td><td>${catNames[t.category]||'Бусад'}</td><td>${t.desc}</td><td class="text-danger font-mono">${fmt(t.amount)}</td></tr>`).join('')}</tbody></table>`;
  } else {
    title.textContent='⚠️ Өр авлагын тайлан — 2025 оны '+thisMonth+'-р сар';
    const paidApts = transactions.filter(t=>t.type==='income'&&t.month===thisMonth).map(t=>t.apt);
    const overdue = residents.filter(r=>!paidApts.includes(r.apt));
    const total = overdue.reduce((s,r)=>s+calcFee(r.sqm),0);
    body.innerHTML=`
      <div class="mb-16"><div class="summary-row"><span class="summary-key">Нийт өр авлага</span><span class="summary-val text-danger">${fmt(total)}</span></div>
      <div class="summary-row"><span class="summary-key">Хэтэрсэн тоот</span><span class="summary-val">${overdue.length}</span></div></div>
      <table><thead><tr><th>Тоот</th><th>Эзэмшигч</th><th>Утас</th><th>Хураамж</th><th>Торгууль (${feeSettings.penalty}%)</th><th>Нийт дүн</th></tr></thead>
      <tbody>${overdue.map(r=>{const fee=calcFee(r.sqm);const penalty=Math.round(fee*feeSettings.penalty/100);return`<tr><td>${r.apt}</td><td>${r.owner}</td><td>${r.phone}</td><td class="font-mono">${fmt(fee)}</td><td class="text-warning font-mono">${fmt(penalty)}</td><td class="text-danger font-mono font-bold">${fmt(fee+penalty)}</td></tr>`;}).join('')}</tbody></table>`;
  }
}

function printReport() { window.print(); }

// ============================================================
// COMMUNICATIONS
// ============================================================
function renderNotifications() {
  const list = document.getElementById('notifications-list');
  const icons = {info:'ℹ️',warning:'⚠️',payment:'💰',maintenance:'🔧'};
  list.innerHTML = notifications.slice().reverse().map(n=>`
    <div class="notif-card">
      <div class="notif-icon">${icons[n.type]||'📢'}</div>
      <div style="flex:1">
        <div class="notif-title">${n.title}</div>
        <div style="font-size:12px;color:var(--text-dim);margin-bottom:4px">${n.content.slice(0,80)}${n.content.length>80?'...':''}</div>
        <div class="notif-meta">${n.date} • ${n.sent} хүнд илгээсэн</div>
      </div>
    </div>`).join('') || '<div class="empty-state"><div class="empty-icon">📭</div><div>Мэдэгдэл байхгүй</div></div>';
}

function sendNotification() {
  const title=document.getElementById('notif-title-input').value.trim();
  const content=document.getElementById('notif-content').value.trim();
  const type=document.getElementById('notif-type').value;
  const recipient=document.getElementById('notif-recipient').value;
  if(!title||!content){toast('Гарчиг болон агуулга оруулна уу','error');return;}
  const recCount = recipient==='all'?residents.reduce((s,r)=>s+r.people,0):
    recipient==='overdue'?5:12;
  const now=new Date();
  notifications.push({id:nextId++,type,title,content,recipient,date:now.toISOString().slice(0,10),sent:recCount});
  document.getElementById('notif-title-input').value='';
  document.getElementById('notif-content').value='';
  renderNotifications();
  toast(`Мэдэгдэл ${recCount} хүнд илгээгдлээ ✓`,'success');
}

function addPollOption() {
  const wrap = document.getElementById('poll-options-wrap');
  const count = wrap.querySelectorAll('.poll-opt').length+1;
  const div=document.createElement('div');div.className='form-group';
  div.innerHTML=`<label>Хариулт ${count}</label><input type="text" class="poll-opt" placeholder="Хариулт...">`;
  wrap.appendChild(div);
}

function createPoll() {
  const q=document.getElementById('poll-question').value.trim();
  const opts=[...document.querySelectorAll('.poll-opt')].map(i=>i.value.trim()).filter(Boolean);
  if(!q||opts.length<2){toast('Асуулт болон 2-оос дээш хариулт оруулна уу','error');return;}
  notifications.push({id:nextId++,type:'info',title:'📊 Санал асуулга: '+q,content:`Хариулт: ${opts.join(', ')}`,recipient:'all',date:new Date().toISOString().slice(0,10),sent:residents.reduce((s,r)=>s+r.people,0)});
  renderNotifications();
  toast('Санал асуулга илгээгдлээ ✓','success');
  document.getElementById('poll-question').value='';
  document.querySelectorAll('.poll-opt').forEach(i=>i.value='');
}

// ============================================================
// EXPENSE MODAL
// ============================================================
function openAddExpense() {
  document.getElementById('exp-date').value = new Date().toISOString().slice(0,10);
  openModal('modal-expense');
}

function saveExpense() {
  const amount=+document.getElementById('exp-amount').value;
  const desc=document.getElementById('exp-desc').value.trim();
  const category=document.getElementById('exp-category').value;
  const date=document.getElementById('exp-date').value;
  if(!amount||!desc){toast('Дүн болон тайлбар оруулна уу','error');return;}
  transactions.push({id:nextId++,apt:null,desc,type:'expense',amount,method:'bank',ref:'',month:+date.split('-')[1],year:+date.split('-')[0],date,status:'completed',category});
  closeModal('modal-expense');
  renderFinanceTable();
  renderExpenses();
  toast('Зарлага нэмэгдлээ ✓','success');
}

// ============================================================
// UTILS
// ============================================================
function methodIcon(m){return{qpay:'📱',bank:'🏦',cash:'💵'}[m]||'💳';}
function methodName(m){return{qpay:'QPay',bank:'Данс шилжүүлэг',cash:'Бэлэн мөнгө'}[m]||m;}

function openModal(id){document.getElementById(id).classList.add('open');}
function closeModal(id){document.getElementById(id).classList.remove('open');}

document.querySelectorAll('.modal-overlay').forEach(m=>{
  m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');});
});

function toast(msg, type='success') {
  const el=document.createElement('div');
  el.className='toast-msg '+type;
  el.innerHTML=(type==='success'?'✅':'❌')+' '+msg;
  document.getElementById('toast').appendChild(el);
  setTimeout(()=>el.remove(),3500);
}

// ============================================================
// INIT
// ============================================================
document.addEventListener('DOMContentLoaded',()=>{
  refreshDashboard();
  // Set today's date in expense form
  document.getElementById('exp-date').value = new Date().toISOString().slice(0,10);
});
</script>
