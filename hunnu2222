const FLOORS = 8;
const APTS_PER_FLOOR = 6;

// Generate all apartment slots
function getAllApts() {
  const apts = [];
  for(let f=1; f<=FLOORS; f++) {
    for(let u=1; u<=APTS_PER_FLOOR; u++) {
      const aptNum = f*100 + u;
      const res = residents.find(r=>r.apt===aptNum);
      apts.push({floor:f, unit:u, aptNum, resident:res||null});
    }
  }
  return apts;
}

function calcFee(sqm) {
  return sqm * feeSettings.perSqm + feeSettings.utility + feeSettings.extra;
}

